# --------------------------------------------------------------------------
# GitHub contribution report - environment configuration
#
# Copy this file to ".env" and fill in real Personal Access Tokens.
#   cp .env.example .env        (macOS/Linux)
#   Copy-Item .env.example .env (Windows PowerShell)
#
# The .env file is loaded automatically when python-dotenv is installed.
# Real environment variables always take precedence over .env values.
# --------------------------------------------------------------------------

# Personal Access Token for the GitHub account "manisharai01".
GITHUB_TOKEN_1=ghp_replace_with_token_for_manisharai01

# Personal Access Token for the GitHub account "manisharai21".
GITHUB_TOKEN_2=ghp_replace_with_token_for_manisharai21

# --------------------------------------------------------------------------
# Using this tool for ANY GitHub user (not just the two above)
# --------------------------------------------------------------------------
# Run:  python github_report.py --user <login>
# The token for <login> is resolved in this order (first one set wins):
#   1. the built-in mapping (manisharai01 -> GITHUB_TOKEN_1, manisharai21 -> GITHUB_TOKEN_2)
#   2. GITHUB_TOKEN_<LOGIN>   (login upper-cased, non-alphanumerics -> "_")
#   3. GITHUB_TOKEN           (single-user convenience)
#
# Examples:
#   GITHUB_TOKEN_OCTOCAT=ghp_xxxx        # then:  python github_report.py --user octocat
#   GITHUB_TOKEN=ghp_xxxx                # then:  python github_report.py --user octocat  (any single user)

# --------------------------------------------------------------------------
# IMPORTANT: token type decides what you can see
# --------------------------------------------------------------------------
# >>> USE A CLASSIC TOKEN (starts with "ghp_") WITH SCOPES: repo, read:org <<<
#
# Only a CLASSIC token with the "repo" scope can read:
#   * your own private repositories,
#   * PRIVATE repos owned by OTHER users where you are a collaborator
#     (this is the common "I committed to a private work repo" case), and
#   * private organization / work repositories (with "read:org").
#
# A FINE-GRAINED token (starts with "github_pat_") CANNOT see repositories
# owned by other users or organizations unless it was explicitly created for
# that owner and granted those repos. It is the usual reason work/private
# commits are missing from the report.
#
# For public-only reporting, "public_repo" + "read:org" is enough.

# --------------------------------------------------------------------------
# Optional: force-include specific repositories / organizations
# --------------------------------------------------------------------------
# Comma- or space-separated. Useful for private/work repos that automatic
# discovery does not surface. (Equivalent to the --repo / --org CLI flags.)
# EXTRA_REPOS=acme/work-backend, acme/work-frontend
# EXTRA_ORGS=acme-corp, my-other-org
